{
  "units": {
    // Output/working length unit. Mechanism geometry is converted to this.
    "length": "mm",

    // Output torque unit for plots/summary/limits.
    "torque": "N.m",

    // Output angle unit for plots/summary.
    "angle": "deg"
  },

  // Number of crank-angle samples across one full 360 deg sweep.
  "n_steps": 720,

  // Gravitational acceleration in mechanism linear units per second squared.
  // For length = "mm", use mm/s^2.
  "gravity": 9806.65,

  // Multiplies all imported linear geometry from the mechanism file.
  // Example: 1.0 keeps the original size, 2.0 doubles all lengths.
  // Must be greater than 0.
  "length_scale": 1.0,

  "motor": {
    // Crank speed in degrees per second.
    "speed_deg_per_s": 10.0,

    // Available motor torque in the configured units.torque.
    "torque_limit": 5.0
  },

  "payload": {
    // Payload force magnitude applied at point E, in N.
    "weight": 22.241108,

    // Payload force direction as a 2D vector [x, y].
    // This is normalized by the code, so only direction matters here.
    "direction": [0.0, -1.0]
  },

  "link_masses": {
    // Link masses in kg.
    "L1": 0.045359,
    "L3": 0.226796,
    "L4": 0.090718,
    "L5": 0.136078,
    "L6": 0.068039
  }
}
